    <!-- Scripts -->
    <script>
        // Data Configuration
        const plansData = [
            { basePrice: 2699, baseMrp: 7999 },
            { basePrice: 4799, baseMrp: 10499 },
            { basePrice: 8899, baseMrp: 14999 },
            { basePrice: 15599, baseMrp: 24999 }
        ];

        const discounts = {
            'Monthly': 1,
            'Quarterly': 0.98,
            'Half-Yearly': 0.95,
            'Annually': 0.85,
            '3 Year': 0.75,
        };

        const exchangeRate = 0.012; // 1 INR = 0.012 USD
        
        // App State
        let state = {
            currency: 'INR',
            billingCycle: 'Monthly',
            currentPrices: plansData.map(p => ({ price: p.basePrice, mrp: p.baseMrp, save: p.baseMrp - p.basePrice }))
        };

        // Initialize App on DOM Load
        document.addEventListener('DOMContentLoaded', () => {
            renderMarquee();
            lucide.createIcons();
            
            setupEventListeners();
            
            // Initial positioning of tab indicator
            setTimeout(() => {
                const initialTab = document.querySelector(`[data-cycle="${state.billingCycle}"]`);
                if(initialTab) updateTabIndicator(initialTab);
            }, 100);
        });

        function renderMarquee() {
            const content = `
                <div class="flex items-center gap-8 px-4 min-w-max">
                    <div class="flex items-center gap-2">
                        <span class="flex h-2 w-2 relative">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-500 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
                        </span>
                        <span class="text-orange-400 font-bold tracking-wider text-xs uppercase">Republic Day Sale</span>
                        <span class="text-slate-600 text-xs">|</span>
                        <span class="text-slate-300 text-sm font-medium">Get <span class="text-white font-bold">FLAT 45% OFF</span> on all Annual & 3-Year Plans</span>
                        <i data-lucide="party-popper" class="text-green-500 w-3.5 h-3.5"></i>
                    </div>
                    <span class="text-slate-700">•</span>
                    <div class="flex items-center gap-2">
                        <span class="text-blue-400 font-bold tracking-wider text-xs uppercase">Limited Time Offer</span>
                        <span class="text-slate-600 text-xs">|</span>
                        <span class="text-slate-300 text-sm font-medium">Claim your <span class="text-white font-bold">Free Domain & SSL</span> with Tech Essentials</span>
                    </div>
                    <span class="text-slate-700">•</span>
                    <div class="flex items-center gap-2">
                        <span class="text-purple-400 font-bold tracking-wider text-xs uppercase">New Launch</span>
                        <span class="text-slate-600 text-xs">|</span>
                        <span class="text-slate-300 text-sm font-medium">Explore <span class="text-white font-bold">Republic Courses</span> - Upskill with Industry Experts</span>
                    </div>
                    <span class="text-slate-700">•</span>
                </div>
            `;
            // Add twice for continuous seamless loop
            const container = document.getElementById('marquee-container');
            container.innerHTML = content + content;
        }

        function setupEventListeners() {
            // Currency Toggle
            document.querySelectorAll('.currency-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const newCurrency = e.target.getAttribute('data-currency');
                    if (state.currency !== newCurrency) {
                        state.currency = newCurrency;
                        updateCurrencyUI();
                        updatePrices();
                        triggerSqueezeAnimation();
                    }
                });
            });

            // Billing Tabs
            document.querySelectorAll('.cycle-tab').forEach(tab => {
                tab.addEventListener('click', (e) => {
                    const newCycle = e.target.getAttribute('data-cycle');
                    if (state.billingCycle !== newCycle) {
                        state.billingCycle = newCycle;
                        updateTabUI(e.target);
                        updateTabIndicator(e.target);
                        updatePrices();
                        triggerSqueezeAnimation();
                    }
                });
            });

            // Checkout Buttons (Loading simulation)
            document.querySelectorAll('.checkout-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const originalContent = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = `<i data-lucide="loader-2" class="animate-spin w-4 h-4 inline-block"></i>`;
                    lucide.createIcons();
                    
                    setTimeout(() => {
                        btn.disabled = false;
                        btn.innerHTML = originalContent;
                        lucide.createIcons();
                    }, 1500);
                });
            });
            
            // Adjust indicator on window resize
            window.addEventListener('resize', () => {
                const activeTab = document.querySelector(`[data-cycle="${state.billingCycle}"]`);
                if(activeTab) updateTabIndicator(activeTab);
            });
        }

        function updateCurrencyUI() {
            document.querySelectorAll('.currency-btn').forEach(btn => {
                if (btn.getAttribute('data-currency') === state.currency) {
                    btn.className = "currency-btn px-6 py-2 rounded-md text-sm font-bold transition-all duration-200 bg-slate-900 text-white shadow-md";
                } else {
                    btn.className = "currency-btn px-6 py-2 rounded-md text-sm font-bold transition-all duration-200 text-slate-600 hover:text-slate-900 hover:bg-white/40";
                }
            });
        }

        function updateTabUI(activeElement) {
            document.querySelectorAll('.cycle-tab').forEach(tab => {
                if (tab === activeElement) {
                    tab.classList.remove('text-slate-600', 'hover:text-slate-900');
                    tab.classList.add('text-white');
                } else {
                    tab.classList.remove('text-white');
                    tab.classList.add('text-slate-600', 'hover:text-slate-900');
                }
            });
        }

        function updateTabIndicator(activeElement) {
            const indicator = document.getElementById('tab-indicator');
            indicator.style.left = activeElement.offsetLeft + 'px';
            indicator.style.width = activeElement.offsetWidth + 'px';
        }

        function triggerSqueezeAnimation() {
            document.querySelectorAll('.pricing-card').forEach(card => {
                card.classList.remove('animate-squeeze');
                // Trigger reflow to restart animation
                void card.offsetWidth; 
                card.classList.add('animate-squeeze');
                
                setTimeout(() => {
                    card.classList.remove('animate-squeeze');
                }, 400);
            });
        }

        // Animated Number Utility
        function animateValue(element, start, end, duration) {
            let startTimestamp = null;
            const locale = state.currency === 'USD' ? 'en-US' : 'en-IN';
            
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                // Ease out quartic
                const ease = 1 - Math.pow(1 - progress, 4);
                const current = Math.floor(start + (end - start) * ease);
                
                element.innerHTML = current.toLocaleString(locale);
                
                if (progress < 1) {
                    window.requestAnimationFrame(step);
                }
            };
            window.requestAnimationFrame(step);
        }

        function updatePrices() {
            const symbol = state.currency === 'USD' ? '$' : '₹';
            const multiplier = discounts[state.billingCycle];
            
            // Update currency symbols
            document.querySelectorAll('.currency-sym').forEach(el => el.innerHTML = symbol);
            
            // Update billing text
            const billingTextStr = state.billingCycle === 'Monthly' ? '/month' : `/mo billed ${state.billingCycle}`;
            document.querySelectorAll('.billing-text').forEach(el => el.innerHTML = billingTextStr);

            // Update each card
            plansData.forEach((plan, i) => {
                // Calculate raw new values
                let newPriceInr = plan.basePrice * multiplier;
                let newMrpInr = plan.baseMrp;
                let newSaveInr = newMrpInr - newPriceInr;

                let finalPrice = newPriceInr;
                let finalMrp = newMrpInr;
                let finalSave = newSaveInr;

                if (state.currency === 'USD') {
                    finalPrice *= exchangeRate;
                    finalMrp *= exchangeRate;
                    finalSave *= exchangeRate;
                }

                finalPrice = Math.ceil(finalPrice);
                finalMrp = Math.ceil(finalMrp);
                finalSave = Math.ceil(finalSave);

                // Animate from current state price to new price
                const currentPriceData = state.currentPrices[i];
                
                animateValue(document.getElementById(`price-val-${i}`), currentPriceData.price, finalPrice, 500);
                animateValue(document.getElementById(`mrp-val-${i}`), currentPriceData.mrp, finalMrp, 500);
                animateValue(document.getElementById(`save-val-${i}`), currentPriceData.save, finalSave, 500);

                // Save new state
                state.currentPrices[i] = { price: finalPrice, mrp: finalMrp, save: finalSave };
            });
        }

    </script>
