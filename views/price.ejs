        @import url('https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&family=Orbitron:wght@400..900&display=swap');
        
        body {
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .font-josefin { font-family: 'Josefin Sans', sans-serif; }
        .font-orbitron { font-family: 'Orbitron', sans-serif; }
        
        @keyframes squeeze {
            0% { transform: scale(1); }
            40% { transform: scale(0.97); }
            100% { transform: scale(1); }
        }

        .animate-squeeze {
            animation: squeeze 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .republic-gradient {
            background: linear-gradient(90deg, #FF9933 0%, #FFFFFF 50%, #138808 100%);
        }

        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .animate-marquee {
            animation: marquee 40s linear infinite;
            width: max-content;
            display: flex;
        }

        /* Pause animation on hover for readability */
        .group:hover .animate-marquee {
            animation-play-state: paused;
        }

        /* Hide scrollbar for tabs but keep functionality */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
